# OpenClaw Environment Configuration
# Copy this file to .env.local and fill with real values.
# Do not commit secrets. `.env.local` is ignored by git and loaded automatically.

# Ollama API Configuration
OLLAMA_API_URL=http://localhost:11434
OLLAMA_API_KEY=

# Web Search Configuration
WEB_SEARCH_API=https://api.ollama.ai/v1/search
WEB_FETCH_API=https://api.ollama.ai/v1/fetch

# GitHub Configuration (ROTATE REGULARLY)
GITHUB_TOKEN=
GITHUB_REPO=Voide-Kali/Claw

# WhatsApp Configuration
WHATSAPP_ENABLED=false
WHATSAPP_SESSION_NAME=default

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=/home/voide/.openclaw/logs/openclaw.log

# Node Environment
NODE_ENV=development

# Database
DATABASE_URL=sqlite:///home/voide/.openclaw/openclaw.db

# API Server
API_PORT=3000
API_HOST=localhost

# Security
ENABLE_RATE_LIMITING=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000

# Feature Flags
FEATURE_WEB_SEARCH=true
FEATURE_VOICE_SYNTHESIS=true
FEATURE_VOICE_RECOGNITION=true
