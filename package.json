{
  "name": "@voide/.openclaw",
  "version": "1.0.0",
  "description": "OpenClaw é uma plataforma de automação e IA para desenvolvimento e operações.",
  "main": "dist/index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "prepare": "husky install",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --single-thread",
    "lint": "eslint . --ext .js,.ts,.jsx,.tsx",
    "lint:fix": "eslint . --ext .js,.ts,.jsx,.tsx --fix",
    "format": "prettier --write \"**/*.{js,ts,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Voide-Kali/Claw.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Voide-Kali/Claw/issues"
  },
  "homepage": "https://github.com/Voide-Kali/Claw#readme",
  "type": "module",
  "dependencies": {
    "dotenv": "^10.0.0",
    "zod": "^3.23.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.9.0",
    "husky": "^9.0.0",
    "jsdom": "^29.0.2",
    "lint-staged": "^14.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.22.1",
    "vitest": "^4.1.4",
    "winston": "^3.10.0"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
